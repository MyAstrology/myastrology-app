{
  "expo": {
    "name": "MyAstrology",
    "slug": "myastrology",
    "scheme": "myastrology",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": ["assets/web/**", "assets/fonts/**", "assets/panjika/**"],
    "android": {
      "package": "in.myastrology.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E8DFCB"
      }
    },
    "ios": {
      "bundleIdentifier": "in.myastrology.app"
    },
    "plugins": [
      "@react-native-google-signin/google-signin",
      ["onesignal-expo-plugin", { "mode": "development" }],
      ["expo-splash-screen", {
        "image": "./assets/splash.png",
        "imageWidth": 220,
        "resizeMode": "contain",
        "backgroundColor": "#FEFAF2"
      }],
      "./plugins/withGradleMemory.js",
      "./plugins/withFixReactGradleProps.js"
    ],
    "extra": {
      "eas": {
        "projectId": "2678cdd7-fa10-4b80-8aa5-f276b88a51a3"
      }
    }
  }
}
