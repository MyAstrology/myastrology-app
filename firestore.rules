rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in [
          'prodyutacharya7@gmail.com',
          'bipulbala64@gmail.com'
        ];
    }

    // অ্যাপ/ওয়েবসাইট লগইন প্রোফাইল — নিজের ডকুমেন্ট নিজে পড়তে/লিখতে পারবে,
    // অ্যাডমিন প্যানেল (AdminScreen.js) সবার তালিকা দেখতে পারবে
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      allow list, get: if isAdmin();
    }

    // ওয়েবসাইটের mya-cloud-sync.js — users/{uid}/data/kundaliProfiles-এ সেভ-করা
    // কুণ্ডলী প্রোফাইল রাখে; উপরের match শুধু users/{uid} ডকুমেন্ট কভার করে,
    // সাব-কালেকশন আলাদা নিয়ম ছাড়া ডিফল্টে বন্ধ থাকত (সিঙ্ক নীরবে ব্যর্থ হতো)
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ওয়েবসাইটের চেকআউট পপআপগুলোর মূল্য/প্রোমো কোড — সবাই পড়তে পারবে,
    // শুধু অ্যাডমিন লিখতে পারবে (pricing-admin.html)
    match /pricing/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // js/social-data.js-এর লাইভ Google/JustDial/Facebook/YouTube রিভিউ ও
    // ফলোয়ার সংখ্যা — সবাই পড়তে পারবে (data-sd badge instant আপডেটের জন্য),
    // শুধু অ্যাডমিন লিখতে পারবে (social-admin.html)
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ওয়েবসাইটের প্রিমিয়াম চেকআউট (kundali.html ইত্যাদি) — গ্রাহক লগইন ছাড়াই
    // অর্ডার তৈরি করেন (শুধু ইমেইল/ফোন দিয়ে), তাই create-এ auth লাগবে না।
    // কিন্তু অর্ডারে জন্মকুষ্ঠি/প্রশ্নের মতো ব্যক্তিগত তথ্য থাকে বলে read/list
    // শুধু অ্যাডমিনের জন্য — অন্য কেউ অন্যের অর্ডার পড়তে/সম্পাদনা করতে পারবে না।
    // hasAll চেকটা ন্যূনতম ফর্ম-জাঙ্ক/স্প্যাম আটকানোর জন্য, নিরাপত্তার মূল
    // স্তর read-restriction-ই।
    match /orders/{orderId} {
      allow create: if request.resource.data.keys().hasAll(['pid', 'email', 'ts'])
                    && request.resource.data.email is string
                    && request.resource.data.ts is number;
      allow read, list, update, delete: if isAdmin();
    }
  }
}
